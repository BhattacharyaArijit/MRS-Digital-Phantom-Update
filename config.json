{
    "skeleton": "MRiLab",
    "path2metabs": "./data/metabolites/metab_df.csv",
    "basis_set_dir": "./simulation/basissets/MRSCloud-main/basis_save/",
    "path2basis": "./data/basissets/LCModel_Universal_Philips_UnEdited_PRESS_TE35.BASIS", #Or select basis as per requirement
    "metabs": [
        []
    ],

    "basis_set_settings":{
        "vendor": "Universal_Seimens",
        "localization": "PRESS",
        "TE": 30
    },

    "simulation_params": {
        "spectral_points": 2048,
        "TR": 2000.0,
        "bandwidth": 2000.0,
        "noise_level": 10.0,

        "mm_level": [10.0],
        "mm_json_file": "./data/macromolecules/mm_params.json",

        "lipid_amp_factor": [10.0],
        "lipid_sigma": [5.0],
        "lipid_phase_min": -180.0,
        "lipid_phase_max": 180.0,
        "lipid_lw_min": 30.0,
        "lipid_lw_max": 50.0,

        "water_amp_factor": 1.0,
        "water_phase_min": 0.0,
        "water_phase_max": 0.0,
        "water_damping_min": 0.0,
        "water_damping_max": 10.0,

        "shim_amplitude_hz": [3.0],
        "shim_corr_length": [0.5],
        "shim_boundary_amp_factor": 1.5,
        "shim_boundary_smoothing": 2.0,
        
            
        "normalize_to_water": false,
        "use_proton_correction": false,
        "save_unsuppressed_water": true
    }
    
}
